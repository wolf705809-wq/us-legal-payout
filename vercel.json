{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "python3 generate_truck_system.py",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/((?!truck|assets|scripts|style|.*\\.css|.*\\.js|.*\\.png|.*\\.jpg|.*\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
