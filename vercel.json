{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/truck-accident/:state/:city",
      "destination": "/truck_template.html"
    },
    {
      "source": "/((?!sitemap.xml|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}