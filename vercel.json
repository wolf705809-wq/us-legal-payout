{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "python3 generate_truck_system.py",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/truck/(.*)",
      "destination": "/truck/$1.html"
    },
    {
      "source": "/((?!assets|scripts|style|truck).*)",
      "destination": "/index.html"
    }
  ]
}
