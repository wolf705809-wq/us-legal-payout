{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/truck/(.*)", "destination": "/truck/$1/index.html" },
    { "source": "/((?!truck|assets|scripts).*)", "destination": "/index.html" }
  ]
}

{
  "builds": [
    {
      "src": "generate_truck_system.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "python3 generate_truck_system.py"
}
